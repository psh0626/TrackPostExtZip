{
  "manifest_version": 3,
  "name": "IMIC TrackPost",
  "description": "Chrome/Edge 확장프로그램 - iCare, GCSS 사무 자동화",
  "version": "3.1.18",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "update_url": "https://raw.githubusercontent.com/psh0626/TrackPostExtZip/main/updateManifest.xml",
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "fonts/PretendardVariable.woff2"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://icare.post/*"
      ],
      "resources": [
        "assets/chunk-DzMEjpoC.js",
        "assets/Portal-C12LDo-X.js",
        "assets/injectUtil-CFwmzvFp.js",
        "assets/compiler-runtime-C3vgDlQ2.js",
        "assets/MenuItem-B34gflbU.js",
        "assets/IMICSettings-DjHHzQWN.js",
        "assets/PostUtil--15dR_qc.js",
        "assets/Message-SViD4mwz.js",
        "assets/serviceAwakener-CxtGZbXx.js",
        "assets/Fab-DsneyvcY.js",
        "assets/utils-BauXrbl-.js",
        "assets/listItemTextClasses-D28lrBkC.js",
        "assets/icareScript.tsx-8pcOngz9.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://gcss.ipc.be/*"
      ],
      "resources": [
        "assets/Portal-C12LDo-X.js",
        "assets/injectUtil-CFwmzvFp.js",
        "assets/IMICSettings-DjHHzQWN.js",
        "assets/exchangeRateUtil-B3Kb4Wjl.js",
        "assets/Message-SViD4mwz.js",
        "assets/utils-BauXrbl-.js",
        "assets/serviceAwakener-CxtGZbXx.js",
        "assets/chunk-DzMEjpoC.js",
        "assets/Fab-DsneyvcY.js",
        "assets/oldGcssScript.tsx-DMRInUXC.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://gcss-uat.ipc.be/*"
      ],
      "resources": [
        "assets/Portal-C12LDo-X.js",
        "assets/injectUtil-CFwmzvFp.js",
        "assets/IMICSettings-DjHHzQWN.js",
        "assets/TimespanExtension-D-wRHErB.js",
        "assets/exchangeRateUtil-B3Kb4Wjl.js",
        "assets/Message-SViD4mwz.js",
        "assets/utils-BauXrbl-.js",
        "assets/newGcssWrapper-DVuQW-O-.js",
        "assets/serviceAwakener-CxtGZbXx.js",
        "assets/chunk-DzMEjpoC.js",
        "assets/Fab-DsneyvcY.js",
        "assets/newGcssScript.ts-DBXQd2IA.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://gcss.ipc.be/*",
        "https://gcss.ipc.be/*",
        "https://gcss.ipc.be/*"
      ],
      "resources": [
        "assets/gcssSumScript-CQmc-QGS.js",
        "assets/serviceAwakener-CxtGZbXx.js",
        "assets/gcssSumScript.ts-60bxZB9o.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://kmmbox.korea.kr/*"
      ],
      "resources": [
        "assets/TimespanExtension-D-wRHErB.js",
        "assets/Message-SViD4mwz.js",
        "assets/serviceAwakener-CxtGZbXx.js",
        "assets/kmmboxScript.ts-84d3H_ur.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://mail.posa.or.kr/*"
      ],
      "resources": [
        "assets/serviceAwakener-CxtGZbXx.js",
        "assets/posamailScript.js-02WPca_a.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "options_page": "src/background-service/ui/options.html",
  "action": {
    "default_popup": "src/background-service/ui/popup.html",
    "default_title": "IMIC TRACKPOST V3"
  },
  "permissions": [
    "storage",
    "tabs",
    "tabGroups",
    "sidePanel",
    "webRequest",
    "clipboardWrite",
    "notifications",
    "unlimitedStorage",
    "scripting"
  ],
  "side_panel": {
    "default_path": "src/background-service/ui/sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "host_permissions": [
    "https://ems.epost.go.kr/*",
    "https://icare.post/*",
    "https://gcss.ipc.be/*",
    "https://gcss-uat.ipc.be/*",
    "https://kmmbox.korea.kr/*",
    "https://mail.posa.or.kr/*",
    "http://localhost:5173/",
    "https://github.com/psh0626/TrackPostExtZip/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/icareScript.tsx-loader-Cbt7VB5p.js"
      ],
      "matches": [
        "https://icare.post/*"
      ],
      "run_at": "document_idle"
    },
    {
      "js": [
        "assets/oldGcssScript.tsx-loader-CL_HgtnO.js"
      ],
      "matches": [
        "https://gcss.ipc.be/*"
      ],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://gcss.ipc.be/CSS/gcss/*/alerts/show/SUM_REPLY",
        "https://gcss.ipc.be/CSS/gcss/*/alerts/show/SUM_REQ",
        "https://gcss.ipc.be/CSS/gcss/*/alerts/show/QUM_REQ"
      ]
    },
    {
      "js": [
        "assets/newGcssScript.ts-loader-CrtKRYnN.js"
      ],
      "matches": [
        "https://gcss-uat.ipc.be/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/newGcssScript-DsQe-Ju9.css"
      ]
    },
    {
      "js": [
        "assets/gcssSumScript.ts-loader-D2n3t6Rs.js"
      ],
      "matches": [
        "https://gcss.ipc.be/CSS/gcss/*/alerts/show/SUM_REPLY",
        "https://gcss.ipc.be/CSS/gcss/*/alerts/show/SUM_REQ",
        "https://gcss.ipc.be/CSS/gcss/*/alerts/show/QUM_REQ"
      ]
    },
    {
      "js": [
        "assets/kmmboxScript.ts-loader-oo7p2uJl.js"
      ],
      "matches": [
        "https://kmmbox.korea.kr/*"
      ]
    },
    {
      "js": [
        "assets/posamailScript.js-loader-BuUMzfhx.js"
      ],
      "matches": [
        "https://mail.posa.or.kr/*"
      ],
      "world": "MAIN"
    }
  ]
}
